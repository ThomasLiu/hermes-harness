#!/usr/bin/env bash
#===============================================================================
# hermes-harness — Hermes AI Development Harness
# 入口脚本，处理 /hg 命令路由
#===============================================================================

set -euo pipefail

# 检测 HARNESS_DIR（优先使用环境变量）
if [[ -z "${HARNESS_DIR:-}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # 向上两级：bin/hg → hermes-harness/（项目根目录）
    HARNESS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

LOG_DIR="$HARNESS_DIR/logs"
TMP_DIR="$HARNESS_DIR/tmp"
CONFIG="$HARNESS_DIR/config.yaml"
PYTHONPATH="$HARNESS_DIR/hermes_harness:${PYTHONPATH:-}"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

#-------------------------------------------------------------------------------
# 工具函数
#-------------------------------------------------------------------------------
log() { echo -e "${BLUE}[harness]${NC} $*"; }
warn() { echo -e "${YELLOW}[harness]${NC} WARN: $*" >&2; }
error() { echo -e "${RED}[harness]${NC} ERROR: $*" >&2; }
success() { echo -e "${GREEN}[harness]${NC} $*" >&2; }

require_tool() {
    if ! command -v "$1" &>/dev/null; then
        error "$1 is required but not installed."
        if [[ -n "${2:-}" ]]; then error "Install: $2"; fi
        exit 1
    fi
}

init_dirs() {
    mkdir -p "$LOG_DIR"/{critical,normal,verbose}
    mkdir -p "$TMP_DIR"
    mkdir -p "$HARNESS_DIR/learn"/{router,coder,reviewer,qa,ship,shared}
    mkdir -p "$HARNESS_DIR/requirements"
    mkdir -p "$HARNESS_DIR/logs/reports"
}

#-------------------------------------------------------------------------------
# 命令路由
#-------------------------------------------------------------------------------
show_help() {
    cat << 'EOF'
Hermes Harness — AI Development Harness

用法: hg <命令> [参数]

命令:
  init             初始化 harness 环境
  new <需求描述>    启动新任务，走完整四阶段流程
  status           查看当前任务状态
  align            交互式需求对齐
  verify           手动触发 checkpoint 验证
  deploy           执行 ship + land-and-deploy
  report           查看今日性能报告
  handoff          查看 handoff 历史
  learn            触发学习分析
  rollback         回滚上一次部署
  test             运行测试
  help             显示帮助

示例:
  hg init
  hg new "帮我做一个用户登录功能"
  hg status
EOF
}

#-------------------------------------------------------------------------------
# 核心命令实现
#-------------------------------------------------------------------------------

cmd_init() {
    log "初始化 Hermes Harness..."
    init_dirs

    if [[ ! -f "$CONFIG" ]]; then
        log "创建默认配置..."
        cat > "$CONFIG" << 'YAML'
# Hermes Harness 配置
version: "1.0"

# MiniMax API（用于 Router/Validator）
minimax:
  model: "MiniMax-Text-01"
  api_key_env: "MINIMAX_API_KEY"
  base_url: "https://api.minimax.io/v1"

# Claude Code（用于执行 gstack skills）
claude_code:
  path: "claude"
  model: "claude-opus-4-7"

# gstack 路径
gstack:
  dir: "~/.claude/skills/gstack"
  auto_update: true

# 三色旗配置
flags:
  yellow_threshold_ai_vs_actual_ratio: 0.2
  stuck_retry_max: 2
  large_file_loc: 200

# 日志配置
logging:
  critical_retention: 5000
  normal_retention: 500
  verbose_retention: 0

# 性能基准（秒）
benchmarks:
  task_completion: 600
  checkpoint_verify: 30
  review_per_file: 60
YAML
        success "配置已创建: $CONFIG"
    else
        log "配置已存在，跳过"
    fi

    log "检查依赖..."
    require_tool "curl"
    require_tool "jq" "brew install jq"
    require_tool "python3" "https://www.python.org/downloads/"
    success "依赖检查通过"
    success "初始化完成！运行 'hg help' 查看可用命令"
}

cmd_new() {
    local requirement="$*"
    if [[ -z "$requirement" ]]; then
        error "请提供需求描述"
        echo "用法: hg new <需求描述>"
        exit 1
    fi

    log "启动新任务: $requirement"
    log "进入 STAGE 0: 需求对齐"

    # 生成 requirement_id
    local req_id
    req_id=$(date +%s)
    local req_dir="$HARNESS_DIR/requirements/$req_id"
    mkdir -p "$req_dir"

    # 保存原始需求
    echo "$requirement" > "$req_dir/requirement.txt"

    # 生成对齐文档框架
    cat > "$req_dir/alignment.yaml" << Yaml
requirement_id: "R$req_id"
original_requirement: "$requirement"
rephrased: "【待确认】"
scope_in: []
scope_out: []
acceptance_criteria: []
risk_statements: []
user_signature: false
ai_signature: false
created_at: "$(date -Iseconds)"
Yaml

    # 记录任务开始
    python3 -c "
import sys
sys.path.insert(0, '$HARNESS_DIR/hermes_harness')
from harness_log import write_log
write_log('critical', 'task_start', requirement_id='R$req_id', requirement='$requirement', intent='pending')
" 2>/dev/null || true

    success "任务已创建: R$req_id"
    echo ""
    echo -e "${YELLOW}请运行以下命令完成需求对齐:${NC}"
    echo -e "  ${GREEN}hg align R$req_id${NC}"
    echo -e "${YELLOW}或直接在需求文档中编辑: $req_dir/alignment.yaml${NC}"
}

cmd_status() {
    log "当前任务状态"
    echo "---"

    local latest_req
    latest_req=$(ls -t "$HARNESS_DIR/requirements/" 2>/dev/null | head -1)

    if [[ -z "$latest_req" ]]; then
        echo "没有运行中的任务"
        return
    fi

    local req_dir="$HARNESS_DIR/requirements/$latest_req"
    echo -e "${BLUE}Requirement ID:${NC} R$latest_req"
    echo -e "${BLUE}需求:${NC} $(cat "$req_dir/requirement.txt" 2>/dev/null || echo 'N/A')"

    if [[ -f "$req_dir/alignment.yaml" ]]; then
        echo -e "${GREEN}✓${NC} 需求对齐已完成"
    else
        echo -e "${YELLOW}○${NC} 需求对齐未完成"
    fi

    if [[ -f "$req_dir/plan.yaml" ]]; then
        echo -e "${GREEN}✓${NC} 规划已完成"
    else
        echo -e "${YELLOW}○${NC} 规划中..."
    fi

    if [[ -f "$req_dir/.hg_flags" ]]; then
        local flag
        flag=$(cat "$req_dir/.hg_flags")
        case "$flag" in
            GREEN)  echo -e "🟢 ${GREEN}GREEN${NC} — 执行中" ;;
            YELLOW) echo -e "🟡 ${YELLOW}YELLOW${NC} — 等待用户输入" ;;
            RED)    echo -e "🔴 ${RED}RED${NC} — 强制人工介入" ;;
        esac
    else
        echo -e "○ 三色旗状态未设置"
    fi

    echo ""
}

cmd_align() {
    local req_id="${1:-}"
    if [[ -z "$req_id" ]]; then
        req_id=$(ls -t "$HARNESS_DIR/requirements/" 2>/dev/null | head -1)
    fi
    if [[ -z "$req_id" ]]; then
        error "没有找到任务，请先运行 hg new <需求>"
        exit 1
    fi

    local req_dir="$HARNESS_DIR/requirements/$req_id"
    local requirement
    requirement=$(cat "$req_dir/requirement.txt")

    echo ""
    echo -e "${BLUE}=== STAGE 0: 需求对齐 ===${NC}"
    echo -e "${BLUE}原始需求:${NC} $requirement"
    echo ""
    echo -e "${GREEN}【请编辑对齐文档】${NC}"
    echo -e "文件: $req_dir/alignment.yaml"
    echo ""
    echo -e "${YELLOW}需要完成:${NC}"
    echo "  1. 需求重述（3句话，用户确认）"
    echo "  2. 边界清单（scope in / scope out）"
    echo "  3. 验收标准 AC1-AC5（可测试）"
    echo "  4. 风险声明"
    echo ""
    echo -e "${GREEN}完成后将 alignment.yaml 中的 user_signature 设为 true${NC}"
}

cmd_verify() {
    local skill="${1:-}"
    local evidence_file="${2:-}"

    if [[ -z "$skill" ]]; then
        # 默认取最新任务
        local latest_req
        latest_req=$(ls -t "$HARNESS_DIR/requirements/" 2>/dev/null | head -1)
        if [[ -z "$latest_req" ]]; then
            error "没有运行中的任务"
            exit 1
        fi

        local req_dir="$HARNESS_DIR/requirements/$latest_req"
        evidence_file="$req_dir/checkpoint_latest.json"
        skill="$(
            grep -m1 'current_skill:' "$req_dir/alignment.yaml" 2>/dev/null \
            || echo '/review'
        )"
        skill="${skill#current_skill: }"
        skill="${skill// /}"
    fi

    log "运行 checkpoint 验证..."
    log "  skill: $skill"

    if [[ -n "$evidence_file" && -f "$evidence_file" ]]; then
        log "  evidence: $evidence_file"
    else
        if [[ -f "$evidence_file" ]]; then
            log "  evidence: (from stdin)"
        else
            warn "未提供 evidence-file，尝试加载: $evidence_file"
        fi
    fi

    # 调用 Python checkpoint 验证器
    local output
    if output=$(PYTHONPATH="$HARNESS_DIR/hermes_harness:$PYTHONPATH" \
        python3 -c "
import sys
import json
from pathlib import Path
sys.path.insert(0, '$HARNESS_DIR/hermes_harness')
from harness_checkpoint import check_evidence

evidence_file = '$evidence_file'
skill = '$skill'

evidence = {}
if evidence_file and Path(evidence_file).exists():
    with open(evidence_file) as f:
        evidence = json.load(f)
elif Path('$HARNESS_DIR/requirements').exists():
    reqs = sorted(Path('$HARNESS_DIR/requirements').glob('*'), reverse=True)
    for req in reqs:
        ck = req / 'checkpoint_latest.json'
        if ck.exists():
            with open(ck) as f:
                evidence = json.load(f)
            break

result = check_evidence(skill, evidence)
print(json.dumps(result, ensure_ascii=False, indent=2))
" 2>&1); then
        echo "$output" | python3 -c "
import sys, json
data = json.load(sys.stdin)
status = data.get('status', 'UNKNOWN')
icon = '✓' if status == 'PASS' else ('✗' if status == 'FAIL' else '○')
print(f\"{'$YELLOW' if status == 'FAIL' else ('$RED' if 'INCOMPLETE' in str(data) else '$GREEN')}{icon} {status}{'$NC'}\")
if data.get('incomplete_reasons'):
    for r in data['incomplete_reasons']:
        print(f'  - {r}')
if data.get('verification_results'):
    for tool, vr in data['verification_results'].items():
        p = 'PASS' if vr.get('passed') else 'FAIL'
        print(f'  {tool}: {p}' + (f\" ({vr.get('error_count', 0)} errors)\" if vr.get('error_count') else ''))
" 2>/dev/null || echo "$output"
    else
        error "checkpoint 验证失败: $output"
        exit 1
    fi
}

cmd_deploy() {
    local req_id="${1:-}"
    if [[ -z "$req_id" ]]; then
        req_id=$(ls -t "$HARNESS_DIR/requirements/" 2>/dev/null | head -1)
    fi
    if [[ -z "$req_id" ]]; then
        error "没有可部署的任务"
        exit 1
    fi

    local req_dir="$HARNESS_DIR/requirements/$req_id"
    local pr_url_file="$req_dir/.pr_url"

    if [[ -f "$pr_url_file" ]]; then
        local pr_url
        pr_url=$(cat "$pr_url_file")
        log "检测到 PR: $pr_url"
        log "请确认后执行 /ship + /land-and-deploy"
        echo ""
        echo -e "${YELLOW}PR URL: $pr_url${NC}"
        echo -e "${YELLOW}下一步: 在 Claude Code 中运行 /ship${NC}"
    else
        log "任务 $req_id 尚未生成 PR"
        log "请先完成 STAGE 2（执行与验证）"
        exit 1
    fi
}

cmd_report() {
    log "今日性能报告"
    echo "---"
    local report_file
    report_file=$(ls -t "$HARNESS_DIR/logs/reports/"daily-*.md 2>/dev/null | head -1)
    if [[ -n "$report_file" && -f "$report_file" ]]; then
        cat "$report_file"
    else
        echo "暂无报告，运行 'hg learn' 生成"
    fi
}

cmd_learn() {
    log "触发学习分析..."
    PYTHONPATH="$HARNESS_DIR/hermes_harness:$PYTHONPATH" \
        python3 -c "
import sys
sys.path.insert(0, '$HARNESS_DIR/hermes_harness')
from harness_analyze import main as analyze_main
analyze_main()
" 2>&1 || { error "分析脚本执行失败"; exit 1; }
    success "分析完成，查看报告: hg report"
}

cmd_handoff() {
    log "Handoff 历史"
    echo "---"
    PYTHONPATH="$HARNESS_DIR/hermes_harness:$PYTHONPATH" \
        python3 -c "
import sys
sys.path.insert(0, '$HARNESS_DIR/hermes_harness')
from harness_log import query_logs
logs = query_logs(levels=['critical'], event_types=['yellow_trigger', 'red_trigger', 'human_input_required'], limit=20)
if logs:
    for log in logs:
        print(log)
else:
    print('暂无 handoff 记录')
" 2>/dev/null || echo "暂无 handoff 记录"
}

cmd_test() {
    log "运行测试..."
    require_tool "python3"
    cd "$HARNESS_DIR" && \
        PYTHONPATH="$HARNESS_DIR/hermes_harness:$PYTHONPATH" \
        python3 -m pytest tests/ -v --tb=short 2>&1
}

cmd_checkpoint() {
    # hg checkpoint <new|advance|status|done|recover|complete|log> [args]
    local action="${1:-}"
    local CHECKPOINT_DIR="$HARNESS_DIR/.checkpoint"
    mkdir -p "$CHECKPOINT_DIR"

    case "$action" in
        new)
            local task_name="${2:-}"
            local total_steps="${3:-5}"
            if [[ -z "$task_name" ]]; then
                error "用法: hg checkpoint new <任务名> [总步骤数]"
                return 1
            fi
            local task_id="task-$(date +%Y%m%d-%H%M%S)"
            local checkpoint_file="$CHECKPOINT_DIR/$task_id.yaml"
            log "创建 checkpoint: $task_name (ID: $task_id, 共 $total_steps 步)"
            cat > "$checkpoint_file" << EOF
# Hermes Harness — 任务 Checkpoint
# 此文件在 context 压缩后用于恢复状态
task: "$task_name"
task_id: "$task_id"
started_at: "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
last_checkpoint: "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
current_step: 0
total_steps: $total_steps
step_description: ""

completed_steps: []
in_progress: null
next_steps: []
files_modified: []
open_issues: []
EOF
            success "创建成功: $checkpoint_file"
            # 设为当前活动任务
            echo "$task_id" > "$CHECKPOINT_DIR/.active"
            echo "active_checkpoint: $task_id" >> "$checkpoint_file"
            ;;

        advance)
            local step_num="${2:-}"
            local description="${3:-}"
            if [[ -z "$step_num" ]]; then
                error "用法: hg checkpoint advance <步骤号> [描述]"
                return 1
            fi
            local active_id
            active_id=$(cat "$CHECKPOINT_DIR/.active" 2>/dev/null || echo "")
            if [[ -z "$active_id" ]]; then
                error "没有活动的 checkpoint，请先 hg checkpoint new <任务名>"
                return 1
            fi
            local checkpoint_file="$CHECKPOINT_DIR/$active_id.yaml"
            if [[ ! -f "$checkpoint_file" ]]; then
                error "Checkpoint 文件不存在: $checkpoint_file"
                return 1
            fi
            log "推进到第 $step_num 步: $description"
            # 使用 python3 更新 YAML（简单可靠的 YAML 更新）
            python3 - "$checkpoint_file" "$step_num" "$description" << 'PYEOF'
import sys, yaml, datetime

f = sys.argv[1]
step = int(sys.argv[2])
desc = sys.argv[3] if len(sys.argv) > 3 else ""

with open(f) as fh:
    data = yaml.safe_load(fh)

data['current_step'] = step
data['step_description'] = desc
data['last_checkpoint'] = datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')

# 如果有 completed_steps，找到当前步，标记为完成
completed = data.get('completed_steps', [])
# 添加新完成的步骤
completed.append({
    'step': step,
    'name': desc,
    'completed_at': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),
})
data['completed_steps'] = completed[-10:]  # 只保留最近10步

with open(f, 'w') as fh:
    yaml.dump(data, fh, allow_unicode=True, default_flow_style=False)

print(f"已更新: step={step}, description={desc}")
PYEOF
            success "Checkpoint 已更新"
            ;;

        status)
            local active_id
            active_id=$(cat "$CHECKPOINT_DIR/.active" 2>/dev/null || echo "")
            if [[ -z "$active_id" ]]; then
                echo "没有活动的 checkpoint"
                return
            fi
            local checkpoint_file="$CHECKPOINT_DIR/$active_id.yaml"
            if [[ ! -f "$checkpoint_file" ]]; then
                error "Checkpoint 文件不存在: $checkpoint_file"
                return 1
            fi
            python3 - "$checkpoint_file" << 'PYEOF'
import sys, yaml

f = sys.argv[1]
with open(f) as fh:
    data = yaml.safe_load(fh)

print("=" * 60)
print(f"任务: {data.get('task', 'N/A')}")
print(f"ID: {data.get('task_id', 'N/A')}")
print(f"开始时间: {data.get('started_at', 'N/A')}")
print(f"最后更新: {data.get('last_checkpoint', 'N/A')}")
print()
print(f"当前进度: 第 {data.get('current_step', 0)} / {data.get('total_steps', '?')} 步")
print(f"当前步骤: {data.get('step_description', 'N/A')}")
print()

completed = data.get('completed_steps', [])
if completed:
    print(f"已完成步骤 ({len(completed)}):")
    for s in completed:
        print(f"  [{s.get('step')}] {s.get('name', 'N/A')} — {s.get('completed_at', '')}")
else:
    print("已完成步骤: (无)")

print()
issues = data.get('open_issues', [])
if issues:
    print(f"待解决问题 ({len(issues)}):")
    for i in issues:
        print(f"  [{i.get('id', '?')}] {i.get('description', 'N/A')} (severity: {i.get('severity', '?')})")

print("=" * 60)
PYEOF
            ;;

        done)
            # 标记任务完成
            local active_id
            active_id=$(cat "$CHECKPOINT_DIR/.active" 2>/dev/null || echo "")
            if [[ -z "$active_id" ]]; then
                error "没有活动的 checkpoint"
                return 1
            fi
            local checkpoint_file="$CHECKPOINT_DIR/$active_id.yaml"
            python3 - "$checkpoint_file" << 'PYEOF'
import sys, yaml, datetime

f = sys.argv[1]
with open(f) as fh:
    data = yaml.safe_load(fh)

data['status'] = 'COMPLETED'
data['completed_at'] = datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')
data['current_step'] = data.get('total_steps', 0)

with open(f, 'w') as fh:
    yaml.dump(data, fh, allow_unicode=True, default_flow_style=False)

print(f"任务已完成: {data.get('task')}")
print(f"完成时间: {data['completed_at']}")
PYEOF
            rm -f "$CHECKPOINT_DIR/.active"
            success "任务已标记为完成"
            ;;

        recover)
            # 从 checkpoint 恢复状态
            local active_id
            active_id=$(cat "$CHECKPOINT_DIR/.active" 2>/dev/null || echo "")
            if [[ -z "$active_id" ]]; then
                error "没有活动的 checkpoint"
                return 1
            fi
            local checkpoint_file="$CHECKPOINT_DIR/$active_id.yaml"
            echo ""
            echo "=== 从 Checkpoint 恢复 ==="
            python3 - "$checkpoint_file" << 'PYEOF'
import sys, yaml

f = sys.argv[1]
with open(f) as fh:
    data = yaml.safe_load(fh)

print(f"任务: {data.get('task')}")
print(f"当前: 第 {data.get('current_step', 0)} / {data.get('total_steps', '?')} 步")
print(f"步骤描述: {data.get('step_description') or '(无)'}")
print()

completed = data.get('completed_steps', [])
if completed:
    print("已完成:")
    for s in completed:
        print(f"  ✓ [{s.get('step')}] {s.get('name')}")

issues = data.get('open_issues', [])
if issues:
    print()
    print("待解决:")
    for i in issues:
        print(f"  ⚠ [{i.get('id')}] {i.get('description')}")

files = data.get('files_modified', [])
if files:
    print()
    print("修改的文件:")
    for ff in files:
        print(f"  • {ff.get('path')} ({ff.get('status')})")
PYEOF
            echo ""
            echo "下一步: $(python3 - "$checkpoint_file" - << 'PYEOF' 2>/dev/null
import sys, yaml
f = sys.argv[1]
with open(f) as fh:
    data = yaml.safe_load(fh)
next_steps = data.get('next_steps', [])
if next_steps:
    print(f"第 {next_steps[0].get('step')} 步: {next_steps[0].get('name')}")
else:
    print("查看 checkpoint status 获取下一步信息")
PYEOF
)"
            ;;

        log)
            # 显示所有 checkpoint 历史
            echo "=== Checkpoint 历史 ==="
            ls -t "$CHECKPOINT_DIR"/*.yaml 2>/dev/null | while read -r f; do
                python3 - "$f" << 'PYEOF' 2>/dev/null
import sys, yaml
f = sys.argv[1]
with open(f) as fh:
    data = yaml.safe_load(fh)
status_icon = "✓" if data.get('status') == 'COMPLETED' else "●"
print(f"{status_icon} [{data.get('task_id', '?')}] {data.get('task', 'N/A')} — 第{data.get('current_step', 0)}/{data.get('total_steps', '?')}步")
PYEOF
            done
            ;;

        "")
            echo "用法: hg checkpoint <new|advance|status|done|recover|log>"
            echo ""
            echo "命令:"
            echo "  new <任务名> [步骤数]   创建新 checkpoint"
            echo "  advance <步骤> [描述]   标记步骤完成"
            echo "  status                 显示当前进度"
            echo "  done                   标记任务完成"
            echo "  recover                从 checkpoint 恢复"
            echo "  log                    显示所有 checkpoint"
            ;;

        *)
            error "未知 checkpoint 操作: $action"
            echo "用法: hg checkpoint <new|advance|status|done|recover|log>"
            ;;
    esac
}

#-------------------------------------------------------------------------------
# 主入口
#-------------------------------------------------------------------------------
main() {
    init_dirs 2>/dev/null || true

    local command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        init)    cmd_init ;;
        new)     cmd_new "$@" ;;
        status)  cmd_status ;;
        align)   cmd_align ;;
        verify)  cmd_verify "$@" ;;
        deploy)  cmd_deploy "$@" ;;
        report)  cmd_report ;;
        learn)   cmd_learn ;;
        handoff) cmd_handoff ;;
        test)    cmd_test ;;
        rollback) cmd_rollback ;;
        checkpoint|ckpt) cmd_checkpoint "$@" ;;
        help|--help|-h|"") show_help ;;
        *)
            error "未知命令: $command"
            show_help
            exit 1
            ;;
    esac
}

# 保留 rollback 简版实现（不影响主流程）
cmd_rollback() {
    log "Rollback 功能"
    echo "暂无部署历史"
}

main "$@"
